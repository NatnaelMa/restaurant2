ance."},loggedInVisitorIdentification:{featureName:"Logged-in visitor identification",description:"Automatically identify returning visitors for personalized chat interactions."},draggableChatWidget:{featureName:"Draggable chat widget",description:"Give your website visitors the option to drag the chat widget from its preset location (bottom left or bottom right) to anywhere on the screen."},conversationalBots:{featureName:"Conversational bots",description:"Deploy chatbots to handle common sales conversations automatically."},ticketCreationLeadQualificationAndMeetingBookingBots:{featureName:"Ticket creation, lead qualification & meeting booking bots",description:"Use pre-built chatbots to qualify leads and schedule meetings."},customBotsCustomBranchingLogicAndAdvancedTargeting:{featureName:"Custom bots, custom branching logic & advanced targeting",description:"Create custom chatbot flows with advanced routing rules."},facebookMessengerIntegration:{featureName:"Facebook Messenger integration",description:"Manage Facebook Messenger conversations directly within HubSpot."},advancedMessengerBotBranchingAndAdvancedReporting:{featureName:"Advanced Messenger bot branching & advanced reporting",description:"Create complex Messenger bot flows with detailed performance analytics."},codeSnippetsForCustomMessengerBotActions:{featureName:"Code snippets for custom Messenger bot actions",description:"Customize Messenger bot behavior using custom code actions."},meetingScheduler:{featureName:"Meeting scheduler ",description:"Let prospects book meetings directly through your calendar availability.",freeTierLimit:"1 personal meeting link",starterTierLimit:"1,000 meeting links",professionalTierLimit:"1,000 meeting links",enterpriseTierLimit:"1,000 meeting links"},aiMeetingAssistant:{featureName:"AI meeting assistant",description:"Use AI to prepare for meetings and automate follow-up tasks."},bookOnBehalfOfOthers:{featureName:"Book on behalf of others",description:"Allow reps to book meetings on behalf of other users, or use round-robin rotation."},leadFormRouting:{featureName:"Lead form routing",description:"Route form submissions directly to meeting scheduling pages."},sharedInbox:{featureName:"Shared inbox",description:"Manage team email and chat communications from a centralized inbox.",freeTierLimit:"1 shared inbox",starterTierLimit:"1 shared inbox",professionalTierLimit:"100 shared inboxes",enterpriseTierLimit:"200 shared inboxes"},conversationRouting:{featureName:"Conversation routing",description:"Automatically assign conversations to the right team members."},customViews:{featureName:"Custom views",description:"Organize shared inbox messages with customizable team views.",professionalTierLimit:"50 custom views",enterpriseTierLimit:"600 custom views"},snippets:{featureName:"Snippets",description:"Insert pre-written responses into emails and chats to answer common questions.",freeTierLimit:"3 snippets",starterTierLimit:"5,000 snippets",professionalTierLimit:"5,000 snippets",enterpriseTierLimit:"5,000 snippets"},tasks:{featureName:"Tasks",description:"Track all customer assignments in one organized system."},taskCalendarSync:{featureName:"Task calendar sync",description:"Sync sales tasks with your preferred calendar automatically."},repeatingTasksAndQueues:{featureName:"Repeating tasks & queues",description:"Automate recurring tasks and organize them into queues."},calling:{featureName:"Calling",description:"Make and receive calls directly in HubSpot with automatic call logging.",starterTierLimit:"500 minutes/month",professionalTierLimit:"3,000 minutes/month",enterpriseTierLimit:"12,000 minutes per account per month"},hubspotProvidedPhoneNumbers:{featureName:"HubSpot-provided phone numbers",description:"Get dedicated business phone numbers for inbound and outbound calls.",starterTierLimit:"1 phone number",professionalTierLimit:"3 phone numbers",enterpriseTierLimit:"5 phone numbers"},interactiveVoiceResponse:{featureName:"Interactive Voice Response (IVR)",description:"Automate call management, reduce wait times, and improve the customer experience through customized routing."},breezeProspectingAgent:{featureName:"Breeze prospecting agent (beta)",description:"Use AI to research prospects and automate personalized outreach."},linkedinSalesNavigatorIntegration:{featureName:"LinkedIn Sales Navigator integration",description:"Access LinkedIn Sales Navigator data and features directly within HubSpot records."},salesWorkspace:{featureName:"Sales workspace",description:"Keep on top of your leads, deals, tasks, and schedule in a personalized workspace."},leads:{featureName:"Leads",description:"Track and qualify leads through customizable pipelines."},guidedActions:{featureName:"Guided actions",description:"Get AI-recommended actions to move leads and deals forward."},sequences:{featureName:"Sequences",description:"Automate personalized email sequences to nurture prospects over time.",professionalTierLimit:"500 email sends/user/day",enterpriseTierLimit:"1,000 email sends/user/day"},dynamicSequences:{featureName:"Dynamic sequences",description:"Automate email sequences that adapt based on prospect engagement."},targetAccounts:{featureName:"Target accounts",description:"Focus your team's efforts on high-value target accounts."},abmToolsAndAutomation:{featureName:"ABM tools & automation",description:"Score and track target accounts with automated ABM workflows."},targetAccountsOverview:{featureName:"Target accounts overview",description:"Monitor engagement and progress across all target accounts."},breezeCopilot:{featureName:"Breeze Assistant (beta)",description:"Get AI-powered assistance for any task, personalized with your CRM data."},deals:{featureName:"Deals",description:"Track and manage sales opportunities through customizable deal stages.",freeTierLimit:"1 deal pipeline",starterTierLimit:"2 deal pipelines",professionalTierLimit:"15 deal pipelines",enterpriseTierLimit:"1,000 deal pipelines"},dealPipelineAutom